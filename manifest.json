{
  "manifest_version": 3,
  "name": "MindMesh",
  "version": "0.1.0",
  "key": "",
  "description": "AI 研究助手 — 追踪你的阅读并帮你做研究",
  "permissions": ["storage", "sidePanel", "activeTab", "tabs", "alarms", "identity"],
  "oauth2": {
    "client_id": "860907233537-lk4e7p31da87s8qo27g81ko0tpheddo0.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/drive.file"]
  },
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "MindMesh — 打开研究面板"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
